# ==========================================================
# Single-Cell-Ann-System 配置文件模板
# 使用方法：
#   1. 把这个文件复制一份，重命名为 .env
#   2. 填入你自己的配置（尤其是 API Key）
#   3. .env 文件不会被提交到 git（已在 .gitignore 中忽略）
# ==========================================================


# ----------------------------------------------------------
# 大模型 API 配置（AI 细胞助手问答功能）
# 二选一填写，推荐智谱 GLM（国内访问稳定，有免费额度）
# ----------------------------------------------------------

# 方案 A：智谱 GLM（推荐）
# 申请地址：https://open.bigmodel.cn/  注册后可获得免费 token
LLM_PROVIDER=zhipu
ZHIPU_API_KEY=your_zhipu_api_key_here
LLM_MODEL=glm-4-flash
LLM_EMBEDDING_MODEL=embedding-3

# 方案 B：OpenAI / DeepSeek / 阿里通义（任何兼容 OpenAI 格式的服务）
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-3.5-turbo
# LLM_BASE_URL=https://api.deepseek.com/v1   # DeepSeek 示例，通义/月之暗面同理

# 可选调参
# LLM_MAX_TOKENS=1024      # 大模型单次最大生成 token 数（默认 1024）
# LLM_TEMPERATURE=0.7      # 生成温度 0~1，越高越随机（默认 0.7）
# LLM_TIMEOUT=60           # API 请求超时秒数（默认 60）


# ----------------------------------------------------------
# Flask Web 服务配置（可选）
# ----------------------------------------------------------

# SECRET_KEY=change-me-to-a-random-string   # Session 加密密钥，生产环境必须修改
# PORT=5000                                  # 服务端口，默认 5000


# ----------------------------------------------------------
# 默认管理员账号（首次启动自动创建）
# ----------------------------------------------------------

# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=Admin@123456
# DEFAULT_ADMIN_NAME=系统管理员
# DEFAULT_ADMIN_EMAIL=admin@example.com


# ----------------------------------------------------------
# 用户管理配置（可选）
# ----------------------------------------------------------

# USER_DB_PATH=data/users.sqlite3            # 自定义用户数据库路径（默认 data/users.sqlite3）
# DEFAULT_NEW_USER_PASSWORD=Nankai@123       # 管理员创建用户时的默认密码


# ----------------------------------------------------------
# ANN 索引参数配置（可选）
# 也可在 API 请求中动态传入，此处为全局默认值
# ----------------------------------------------------------

# CELL_INDEX_BACKEND=auto       # 索引后端：auto / faiss / hnswlib / numpy
# CELL_INDEX_TYPE=flat          # 索引类型：flat / ivf_flat / hnsw / pq / brute
# CELL_INDEX_METRIC=l2          # 距离度量：l2 / cosine / ip
# CELL_INDEX_NLIST=100          # IVF 分桶数量
# CELL_INDEX_NPROBE=10          # IVF 查询探测数量
# CELL_INDEX_M=16               # HNSW 图的 M 参数
# CELL_INDEX_EF_CONSTRUCTION=200 # HNSW 构建质量参数
# CELL_INDEX_EF_SEARCH=50       # HNSW 查询质量参数
# CELL_INDEX_PQ_M=8             # PQ 子空间数量（需整除向量维度）
# CELL_INDEX_PQ_NBITS=8         # PQ 编码位数（1-16）
